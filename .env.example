# =============================================================================
# Fortify ScanCentral SAST – Docker Setup
# =============================================================================

# --- Image Versions ---------------------------------------------------------
SCANCENTRAL_SAST_VERSION=25.4.0

# --- Network ----------------------------------------------------------------
# Name of the Docker network. Must match the network used by your SSC instance.
# Default: "fortify" (if SSC was started with "docker network create fortify")
# If you're using the fortify-ssc-docker-setup repo without a custom network,
# the network name is typically "fortify-ssc-docker-setup_fortify".
# Check with: docker network ls | grep fortify
DOCKER_NETWORK_NAME=fortify

# --- Ports ------------------------------------------------------------------
SCANCENTRAL_HOST_PORT=9443

# --- Volume Paths -----------------------------------------------------------
DOCKER_HOST_VOLUME_SECRETS=./volumes/secrets
DOCKER_HOST_VOLUME_DATA=./volumes/data

# --- Controller Configuration -----------------------------------------------
# SSC URL (must be reachable from the controller container)
SCANCENTRAL_CONFIG_SSC_URL=https://ssc-webapp:8443
# Controller URL
SCANCENTRAL_CONFIG_THIS_URL=https://sast-ctrl:8443/scancentral-ctrl
# Allow SSC requests from any IP (required for Docker networking)
SCANCENTRAL_CONFIG_SSC_REMOTE_IP=0.0.0.0/0

# Auth tokens (shared between SSC, Controller, and Worker)
# Generated by setup.sh or manually with: openssl rand -hex 32
SCANCENTRAL_WORKER_AUTH_TOKEN_FILE=/etc/secrets/scancentral-worker-auth-token
SCANCENTRAL_CLIENT_AUTH_TOKEN_FILE=/etc/secrets/scancentral-client-auth-token
SCANCENTRAL_SSC_SECRET_FILE=/etc/secrets/scancentral-ssc-scancentral-ctrl-secret

# HTTPS certificate (JKS format)
HTTP_SERVER_CERTIFICATE_KEYSTORE_FILE=/etc/secrets/httpKeystore.jks
HTTP_SERVER_CERTIFICATE_KEYSTORE_PASSWORD_FILE=/etc/secrets/keystore_password
HTTP_SERVER_CERTIFICATE_KEY_PASSWORD_FILE=/etc/secrets/keystore_password

# Truststore for certificate validation
SCANCENTRAL_TRUSTSTORE_PATH=/etc/secrets/truststore.jks
SCANCENTRAL_TRUSTSTORE_PASSWORD_FILE=/etc/secrets/truststore_password

# Logging
SCANCENTRAL_LOG_LEVEL=info

# --- Worker Configuration ---------------------------------------------------
SCANCENTRAL_ENABLE=1
# Controller URL (from the worker's perspective)
SCANCENTRAL_URL=https://sast-ctrl:8443/scancentral-ctrl/

# Rulepack updates
FORTIFY_UPDATE_AUTO=1
FORTIFY_UPDATE_ACCEPT_KEY=1
FORTIFY_UPDATE_ACCEPT_SSL_CERTIFICATE=1
