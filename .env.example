# =============================================================================
# Fortify ScanCentral SAST – Docker Setup
# =============================================================================

# --- Image Versions ---------------------------------------------------------
SCANCENTRAL_SAST_VERSION=25.4.0

# --- Network ----------------------------------------------------------------
# Name of the Docker network. Must match the network used by your SSC instance.
# If you're using the fortify-ssc-docker-setup repo, the default is "fortify".
DOCKER_NETWORK_NAME=fortify

# --- Ports ------------------------------------------------------------------
SCANCENTRAL_HOST_PORT=9443

# --- Volume Paths -----------------------------------------------------------
DOCKER_HOST_VOLUME_SECRETS=./volumes/secrets
DOCKER_HOST_VOLUME_DATA=./volumes/data

# --- SSC Connection ---------------------------------------------------------
# URL of your Fortify SSC instance. If SSC is running on the same Docker network
# (e.g., from the fortify-ssc-docker-setup repo), use the container name:
SCANCENTRAL_SSC_URL=https://ssc-webapp:8443

# --- Controller Configuration -----------------------------------------------
SCANCENTRAL_CTRL_URL=https://sast-ctrl:8443/scancentral-ctrl

# Auth token shared between SSC, Controller, and Worker.
# Generate with: openssl rand -hex 32
SCANCENTRAL_CTRL_AUTHTOKEN_FILE=/etc/secrets/scancentral-authtoken

# HTTPS certificate
SCANCENTRAL_CTRL_HTTP_CERT_FILE=/etc/secrets/scancentral-keystore.pfx
SCANCENTRAL_CTRL_HTTP_CERT_PASSWORD_FILE=/etc/secrets/keystore_password

# Database (embedded H2 by default)
SCANCENTRAL_CTRL_DB_TYPE=H2_EMBEDDED
SCANCENTRAL_CTRL_DB_MIGRATION_ENABLED=true

# --- Worker Configuration ---------------------------------------------------
SCANCENTRAL_WORKER_ENABLED=true
SCANCENTRAL_WORKER_AUTHTOKEN_FILE=/etc/secrets/scancentral-authtoken
SCANCENTRAL_WORKER_CTRL_URL=https://sast-ctrl:8443/scancentral-ctrl/

# Trust the controller's self-signed certificate
SCANCENTRAL_WORKER_TRUSTSTORE_FILE=/etc/secrets/scancentral-truststore.jks
SCANCENTRAL_WORKER_TRUSTSTORE_PASSWORD_FILE=/etc/secrets/truststore_password

# Rulepack updates
SCANCENTRAL_WORKER_FORTIFY_UPDATE_ENABLED=true
SCANCENTRAL_WORKER_FORTIFY_UPDATE_ACCEPT_KEY=true
SCANCENTRAL_WORKER_FORTIFY_UPDATE_ACCEPT_SSL_CERT=true
